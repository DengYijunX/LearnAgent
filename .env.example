# =============================================================================
# LearnAgent Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NOT be committed.

# --- DeepSeek API ---
# API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Base URL for DeepSeek OpenAI-compatible API
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Small model for daily use (fast, cheap).
# Set to the actual model ID for DeepSeek V4 Flash or equivalent.
# Examples: "deepseek-chat" (auto-routes to latest), or a specific model ID.
DEEPSEEK_SMALL_MODEL=deepseek-chat

# Large model for complex tasks (deep reasoning, planning, repo analysis).
# Set to the actual model ID for DeepSeek V4 Pro or equivalent.
# Examples: "deepseek-reasoner" (auto-routes to latest), or a specific model ID.
DEEPSEEK_LARGE_MODEL=deepseek-reasoner

# --- Model mode ---
# Controls which model is selected by ModelSelector.
# Options: normal | summary | lightweight | deep | planning | repo_analysis
LEARNAGENT_MODEL_MODE=normal

# --- LLM parameters ---
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# --- Test configuration ---
# Set to 1 to enable integration tests that call real APIs.
# These tests require DEEPSEEK_API_KEY and will consume credits.
RUN_REAL_TESTS=0
