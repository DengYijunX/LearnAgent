# LLM Provider: anthropic | deepseek | openai
LLM_PROVIDER=anthropic

# 通用 API Key（provider 专属 key 为空时使用）
# LLM_API_KEY=sk-xxx

# OpenAI 兼容 API 的 base_url（DeepSeek 需要：https://api.deepseek.com）
# LLM_BASE_URL=

# 模型名（按复杂度，不设则用 provider 默认）
# LLM_MODEL_SIMPLE=
# LLM_MODEL_COMPLEX=

# Provider 专属 Key
ANTHROPIC_API_KEY=sk-ant-xxx
DEEPSEEK_API_KEY=sk-xxx
OPENAI_API_KEY=sk-xxx

# 搜索
TAVILY_API_KEY=tvly-xxx

# Jina AI Reader（可选，没有也能用 httpx 抓取）
JINA_API_KEY=jina_xxx

# GitHub（可选，公开仓库不需要 token，但有 token 速率更高）
GITHUB_TOKEN=ghp_xxx

# 通知
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# 日志
LOG_LEVEL=DEBUG
